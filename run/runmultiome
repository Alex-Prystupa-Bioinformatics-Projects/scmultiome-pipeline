#!/bin/bash
# =============================================================================
# runmultiome  |  Pipeline Entry Point
# =============================================================================
# Central script for submitting pipeline jobs to the HPC scheduler.
# Auto-detects SLURM or LSF and submits accordingly.
#
# Usage:
#   bash run/runmultiome <function_name>
#
# Available functions:
#   init                   — set up directory structure for a new project
#   preprocess             — run steps 1-4 (init → create → callpeaks → qc)
#   filter_merge_reduce    — run steps 5-8 (filter → merge → normalize/reduce → markers)
#   annotate_recall_peaks  — run steps 9-10 (annotate cell types → recall peaks)
#   linkpeaks              — run step 11 (per-group parallel LinkPeaks)
#
# Example:
#   bash run/runmultiome preprocess
# =============================================================================

# Environment variables — set these before running
export project_prefix=jm-multiome
export my_macs_path=/sc/arion/projects/naiklab/daccache/.hidden-libraries/miniconda3/envs/joe-macs3/bin/macs3
export personal_anaconda_path=/sc/arion/projects/naiklab/daccache/.hidden-libraries/miniconda3/etc/profile.d/conda.sh
export conda_env_name=sc-multiome-pipeline-env
export sceasy_env_name=sceasy-joe
export scenicplus_env_name=scenicplus-joe
export create_cistarget_databases_path=/sc/arion/projects/naiklab/daccache/.hidden-libraries/miniconda3/envs/scenicplus-joe/create_cisTarget_databases

# Detect scheduler based on environment variables
detect_scheduler() {
    if [ ! -z "$SLURM_JOB_ID" ]; then
        echo "SLURM detected"
        export SCHEDULER="slurm"
    elif [ ! -z "$LSF_ENVDIR" ]; then
        echo "LSF detected"
        export SCHEDULER="lsf"
    else
        echo "No known job scheduler detected"
        export SCHEDULER="none"
    fi
}

# Submit a job to the detected scheduler
# Usage: submit_job <script> <out> <err> <time> <mem> <cores>
submit_job() {
    local script=$1
    local output=$2
    local error=$3
    local time=$4
    local mem=$5
    local cores=$6

    if [ "$SCHEDULER" == "slurm" ]; then
        time=0-$time:00
        sbatch -c $cores -p a100_short --mem-per-cpu $mem -o $output -e $error -t $time --export=ALL $script
    elif [ "$SCHEDULER" == "lsf" ]; then
        bsub -P acc_naiklab -q premium -n $cores -R "rusage[mem=$mem]" -R span[hosts=1] -o $output -e $error -W $time $script
    else
        echo "No job scheduler available to submit job: $script"
    fi
}

# Set up directory structure and restore R environment for a new project
init() {
    echo "Initializing project directory structure"
    bash routes/setup_dirs.sh

    # Restore renv library on the login node (has internet access).
    # renv::install('renv') ensures renv itself is in the project library so
    # compute nodes don't need to bootstrap it from the internet.
    # The login node's OS platform prefix is saved to .renv_platform so that
    # 01_preprocess.sh can point compute nodes to the correct library path
    # (login and compute nodes may run different OS minor versions on Minerva).
    echo "Restoring R environment via renv (this may take a few minutes)..."
    module load R/4.4.1
    Rscript -e "renv::install('renv'); renv::restore()" && \
        Rscript --no-init-file -e "cat(renv:::renv_platform_prefix())" > .renv_platform
    echo "R environment restored."

    echo "Syncing Python environment via uv..."
    uv sync
    echo "Python environment ready."
    echo ""
    echo "Next steps:"
    echo "  1. Fill in configs/samplesheet.csv with your samples"
    echo "  2. Edit configs/pipeline_config.yml with your species/genome settings"
    echo "  3. Run: run/runmultiome preprocess"
}

# Phase 1: full preprocessing pipeline (steps 1-4)
# Runs: init → create → callpeaks → qc
# Time: 24hrs | Mem: 24GB/core | Cores: 12
preprocess() {
    echo "Submitting preprocessing pipeline (steps 1-4)"
    submit_job routes/01_preprocess.sh \
        scripts/outs/preprocessing-%J.out \
        scripts/outs/preprocessing-%J.err \
        24:00 24000 12
}

# Phase 2: filter, merge, normalize/reduce pipeline (steps 5-7)
# Steps 5-6 are skipped automatically if the merged RDS already exists.
# Time: 12hrs | Mem: 16GB/core | Cores: 8
filter_merge_reduce() {
    local merge_rds="output/RDS-files/${project_prefix}-06-merge-obj.RDS"
    if [ -f "$merge_rds" ]; then
        echo "Merged RDS found — submitting step 7 only (normalize/reduce)"
        echo "  Skipping: steps 5 (filter) and 6 (merge)"
        echo "  To force full re-run: rm $merge_rds"
    else
        echo "Submitting full pipeline: filter (5) → merge (6) → normalize/reduce (7)"
    fi
    submit_job routes/02_filter_merge_reduce.sh \
        scripts/outs/filter-merge-reduce-%J.out \
        scripts/outs/filter-merge-reduce-%J.err \
        12:00 16000 8
}

# Phase 3: annotate cell types + recall peaks (steps 9-10)
# Time: 12hrs | Mem: 16GB/core | Cores: 8
annotate_recall_peaks() {
    echo "Submitting annotation + recall peaks pipeline (steps 9-10)"
    submit_job routes/03_annotate_recall_peaks.sh \
        scripts/outs/annotate-recall-peaks-%J.out \
        scripts/outs/annotate-recall-peaks-%J.err \
        12:00 16000 8
}

# Phase 4: per-group parallel LinkPeaks (step 11)
# Orchestrator job is lightweight (2hrs, 4 cores) — it splits the object,
# then submits one child LSF job per group (each 36hrs, 16 cores, 64GB).
# Set linkpeaks_grouping_col in configs/pipeline_config.yml before running.
linkpeaks() {
    echo "Submitting LinkPeaks orchestrator (step 11)"
    echo "  Grouping column: see configs/pipeline_config.yml -> linkpeaks_grouping_col"
    submit_job routes/04_linkpeaks.sh \
        scripts/outs/linkpeaks-%J.out \
        scripts/outs/linkpeaks-%J.err \
        2:00 32000 4
}

# Dispatcher — calls the named function passed as argument
run_multiome() {
    if [ $# -eq 0 ]; then
        echo "Please provide a function name to run."
        echo "Available: init, preprocess, filter_merge_reduce, annotate_recall_peaks, linkpeaks"
        exit 1
    fi
    "$1"
}

# Detect scheduler then dispatch
detect_scheduler
run_multiome "$1"
